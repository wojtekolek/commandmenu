{
  "name": "commandmenu",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "changeset": "changeset",
    "version-package": "changeset version",
    "publish-package": "turbo run build lint --filter=website^... && changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@changesets/cli": "2.30.0",
    "turbo": "2.9.5"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24.14"
  }
}
