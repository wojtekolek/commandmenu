{
  "name": "commandmenu",
  "version": "0.5.0",
  "author": "Wojtek Olek",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wojtekolek/commandmenu",
    "directory": "packages/commandmenu"
  },
  "keywords": [
    "command",
    "menu",
    "react",
    "nextjs"
  ],
  "files": [
    "dist",
    "package.json"
  ],
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts",
    "dev": "tsup src/index.ts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist"
  },
  "devDependencies": {
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "jsdom": "29.0.1",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tsup": "8.5.1",
    "typescript": "catalog:",
    "vitest": "4.1.0"
  },
  "peerDependencies": {
    "react": "^19.1.0",
    "typescript": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  }
}
