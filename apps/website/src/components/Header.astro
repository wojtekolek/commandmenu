---
import { CopyInstallButton } from "./CopyInstallButton";

const version = "0.5.2";
const packageName = "commandmenu";
const npmUrl = `https://www.npmjs.com/package/${packageName}`;
const githubUrl = "https://github.com/wojtekolek/commandmenu";
const description = "Headless UI for building command menus in React.";
---

<header class="relative flex flex-col items-center gap-6 rounded-t-3xl bg-linear-to-b from-secondary-200/50 to-transparent py-21 lg:pt-40 lg:pb-21 section-spacing text-center">
  <a
    href={npmUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="absolute top-6 left-6 rounded-full border border-primary-200 px-3 py-1 text-xs text-primary-500 transition-colors hover:border-primary-300 hover:text-primary-700 lg:top-10 lg:left-10"
  >
    v{version}
  </a>

  <a
    href={githubUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="absolute top-6 right-6 flex items-center gap-1.5 px-3 py-1 text-xs text-primary-500 transition-colors hover:text-primary-700 lg:top-10 lg:right-10"
  >
    <svg class="size-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
      <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z" />
    </svg>
    GitHub
  </a>

  <h1 class="font-display text-6xl text-primary-900 drop-shadow tracking-widest lg:text-6xl">
    Command Menu
  </h1>

  <p class="max-w-md text-primary-500 text-sm lg:text-base">
    {description}
  </p>

  <CopyInstallButton client:load packageName={packageName} />
</header>
